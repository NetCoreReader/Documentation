<UserControl x:Class="OverPay.UserController.UserSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OverPay.UserController"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="1" Grid.Row="1">
            <StackPanel>
                <Label Margin="0,20" Content="Eşleşme Ayarları" HorizontalAlignment="Left" FontSize="30" FontWeight="ExtraBlack" Width="253"/>
                <Line Name="line" Stroke="Black" StrokeThickness="2" X1="-50" X2="300" Y1="-15" Y2="-15"/>
                <DockPanel Margin="-115,7">
                    <Label Content="IP :" FontSize="20" FontWeight="DemiBold"/>
                    <TextBox x:Name="IPTxt" HorizontalAlignment="Left" TextWrapping="Wrap" Width="240" Height="30"/>
                </DockPanel>
                <DockPanel Margin="-115,7">
                    <Label Content="Port :" FontSize="20" FontWeight="DemiBold"/>
                    <TextBox x:Name="PortTxt" HorizontalAlignment="Left" TextWrapping="Wrap"  Width="240" Height="30"/>
                </DockPanel>
                <DockPanel Margin="-135,7">
                    <Label Content="Seri Numarası :" FontSize="18" FontWeight="DemiBold" Width="150"/>
                    <TextBox x:Name="SerialNumberTxt" HorizontalAlignment="Left" TextWrapping="Wrap"  Width="240" Height="30"/>
                </DockPanel>
                <Button Content="Güncelle" Margin="-10,10,0,0" Click="UpdatePairingConfiguration_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
