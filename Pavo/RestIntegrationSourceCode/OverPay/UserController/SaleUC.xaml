        <Border Grid.Row="3">
            <StackPanel>
                    <Label FontWeight="DemiBold">Döviz Bilgisi</Label>
                <Line Name="line" Stroke="Black" StrokeThickness="1" X1="0" X2="120" Y1="0" Y2="0"/>
                    <DockPanel Margin="2,6" HorizontalAlignment="Left">
                        <Label>Döviz kodu:</Label>
                    <ComboBox x:Name="currencyCmb" SelectedIndex="0"></ComboBox>
                </DockPanel>
                    <DockPanel Margin="2,4" HorizontalAlignment="Left">
                        <Label>Döviz kuru:</Label>
                    <TextBox x:Name="exchangeRateTxt" Margin="25,0,0,0"></TextBox>
                    </DockPanel>
            </StackPanel>
        </Border>
        <Border Grid.Row="4" Margin="0,20,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0">
                    <Button x:Name="CancelSaleBtn"  Grid.Column="0" Grid.Row="4"  Content="İptal" Background="#E74C3C" Click="CancelSaleBtn_Click"/>
                </Border>
                <Border Grid.Column="1">
                    <Label x:Name="TotalPriceLabel" HorizontalAlignment="Center"  Grid.Row="4" Grid.Column="1" />
                </Border>
                <Border Grid.Column="2">
                    <Button x:Name="CompleteSaleBtn"  Width="150" Click="CompleteSale"  Grid.Column="2" HorizontalAlignment="Center" Grid.Row="4" Content="Satışı Tamamla"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
